{
    "extends": "./tsconfig.json",
    "include": [
        "backend/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "test",
        "dist",
        "**/*spec.ts",
        "components",
        "src"
    ],
    "compilerOptions": {
        "target": "ES2021",
        "module": "commonjs",
        "moduleResolution": "node",
        "allowImportingTsExtensions": false,
        "noEmit": false,
        "outDir": "./dist",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "strictNullChecks": false,
        "downlevelIteration": true
    }
}