{
  "name": "gozipp-platform",
  "version": "1.0.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "docker:build": "docker build -t gozipp-app .",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "db:backup": "docker exec -t gozipp-db pg_dumpall -c -U gozipp_user > backup_$(date +%Y-%m-%d).sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/websockets": "^10.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tanstack/react-query": "^5.17.9",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.312.0",
    "next": "16.2.4",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "querystring": "^0.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "typeorm": "^0.3.19",
    "zustand": "^4.5.0",
    "@google/genai": "latest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.8",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.5",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "turbo": "^1.12.0"
  }
}
