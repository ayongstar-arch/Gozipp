# =============================================================
# GOZIPP Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values

# --- Database (PostgreSQL + PostGIS) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=gozipp_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Security ---
JWT_SECRET=your-very-long-and-secure-secret-minimum-64-chars-change-this
WALLET_SECRET=GOZIPP_TX_SECURE_2026_CHANGE_ME

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- SMS Service (ThaiBulkSMS) ---
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_ID=GOZIPP

# --- OAuth ---
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CALLBACK_URL=http://localhost:3000/api/v1/auth/line/callback

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# --- AI Service (Local Ollama) ---
LOCAL_AI_URL=http://localhost:11434/api/generate
LOCAL_AI_MODEL=typhoon

# --- AWS S3 (File Uploads) ---
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=gozipp-uploads

# --- Maps ---
GOOGLE_MAPS_API_KEY=your-google-maps-key

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Development Helpers ---
ALLOW_TEST_OTP=true   # Allows OTP=123456 in dev mode only

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key
